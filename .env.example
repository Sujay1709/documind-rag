# Copy to .env and adjust as needed. All variables are optional.

# Ollama server
DOCUMIND_OLLAMA_BASE_URL=http://localhost:11434
DOCUMIND_CHAT_MODEL=llama3.2:3b
DOCUMIND_EMBEDDING_MODEL=nomic-embed-text:latest
DOCUMIND_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Chunking / retrieval
DOCUMIND_CHUNK_SIZE=1000
DOCUMIND_CHUNK_OVERLAP=200
DOCUMIND_N_RESULTS=30
DOCUMIND_TOP_K_RERANK=12

# Uploads (display only; the enforced limit is maxUploadSize in .streamlit/config.toml
# and 500 MB in src/documind/webapp.py)
DOCUMIND_MAX_UPLOAD_MB=500

# Storage
DOCUMIND_PERSIST_DIR=./.documind/chroma
DOCUMIND_COLLECTION_NAME=documind

# Web API hardening (optional)
# DOCUMIND_API_TOKEN=changeme      # require X-Documind-Token on /upload and /chat
# DOCUMIND_RATE_LIMIT_PER_MIN=20   # per-visitor chat rate limit
# DOCUMIND_SUMMARIZE_ON_UPLOAD=true  # set false in public demos to save an LLM pass
# DOCUMIND_MAX_ANSWER_TOKENS=1500
# DOCUMIND_UPLOAD_DIR=./uploads     # admin path-upload reads from this dir only
