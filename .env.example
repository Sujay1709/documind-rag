# Copy to .env and adjust as needed. All variables are optional.

# Ollama server
DOCUMIND_OLLAMA_BASE_URL=http://localhost:11434
DOCUMIND_CHAT_MODEL=llama3.2:3b
DOCUMIND_EMBEDDING_MODEL=nomic-embed-text:latest
DOCUMIND_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Chunking / retrieval
DOCUMIND_CHUNK_SIZE=400
DOCUMIND_CHUNK_OVERLAP=100
DOCUMIND_N_RESULTS=10
DOCUMIND_TOP_K_RERANK=3

# Uploads (display only; the enforced limit is maxUploadSize in .streamlit/config.toml)
DOCUMIND_MAX_UPLOAD_MB=500

# Storage
DOCUMIND_PERSIST_DIR=./.documind/chroma
DOCUMIND_COLLECTION_NAME=documind
